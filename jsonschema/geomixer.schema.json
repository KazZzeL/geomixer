{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/KazZzeL/geomixer/jsonschema/geomixer.schema.json",
  "$ref": "#/$defs/Config",
  "$defs": {
    "Category": {
      "properties": {
        "name": {
          "type": "string",
          "description": "Category name",
          "examples": [
            "CN"
          ]
        },
        "steps": {
          "items": {
            "$ref": "#/$defs/Step"
          },
          "type": "array",
          "description": "Ordered list of transformation steps"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "steps"
      ]
    },
    "Config": {
      "anyOf": [
        {
          "required": [
            "geosite"
          ]
        },
        {
          "required": [
            "geoip"
          ]
        }
      ],
      "properties": {
        "geosite": {
          "$ref": "#/$defs/Runner",
          "description": "Domain (geosite) rules configuration"
        },
        "geoip": {
          "$ref": "#/$defs/Runner",
          "description": "IP (geoip) rules configuration"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Input": {
      "if": {
        "properties": {
          "kind": {
            "enum": [
              "geofile",
              "plain"
            ]
          }
        }
      },
      "then": {
        "oneOf": [
          {
            "required": [
              "url"
            ]
          },
          {
            "required": [
              "path"
            ]
          }
        ]
      },
      "else": {
        "if": {
          "properties": {
            "kind": {
              "const": "list"
            }
          }
        },
        "then": {
          "required": [
            "list"
          ]
        }
      },
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique name referenced by steps"
        },
        "kind": {
          "type": "string",
          "enum": [
            "geofile",
            "plain",
            "list"
          ],
          "description": "Source type"
        },
        "url": {
          "type": "string",
          "description": "Remote URL for geofile or plain input",
          "examples": [
            "https://example.com/data.dat"
          ]
        },
        "path": {
          "type": "string",
          "description": "Local file path as alternative to remote url",
          "examples": [
            "./data.dat"
          ]
        },
        "list": {
          "items": {
            "type": "string",
            "examples": [
              "10.0.0.0/8",
              "example.com"
            ]
          },
          "type": "array",
          "description": "Inline CIDR or domain rules for list input"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "kind"
      ]
    },
    "Options": {
      "properties": {
        "ignore_ip_v4": {
          "type": "boolean",
          "description": "Drop IPv4 CIDRs from geoip processing"
        },
        "ignore_ip_v6": {
          "type": "boolean",
          "description": "Drop IPv6 CIDRs from geoip processing"
        },
        "skip_attrs_on_dedup": {
          "type": "boolean",
          "description": "When true dedup uses domain without attrs so same domain with different attrs is merged"
        },
        "reset_attrs": {
          "type": "boolean",
          "description": "Remove all existing domain attributes before applying other options"
        },
        "delete_attrs": {
          "items": {
            "type": "string",
            "examples": [
              "ads"
            ]
          },
          "type": "array",
          "description": "Drop specific attribute keys from domain"
        },
        "append_attrs": {
          "items": {
            "type": "string",
            "examples": [
              "tracking"
            ]
          },
          "type": "array",
          "description": "Add boolean attributes to domain rules"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Output": {
      "properties": {
        "name": {
          "type": "string",
          "description": "Output filename",
          "examples": [
            "geosite.dat"
          ]
        },
        "dir": {
          "type": "string",
          "description": "Output directory override",
          "examples": [
            "./dist"
          ]
        },
        "categories": {
          "items": {
            "$ref": "#/$defs/Category"
          },
          "type": "array",
          "description": "List of categories to build"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "categories"
      ]
    },
    "Runner": {
      "properties": {
        "inputs": {
          "items": {
            "$ref": "#/$defs/Input"
          },
          "type": "array",
          "description": "Named data sources"
        },
        "outputs": {
          "items": {
            "$ref": "#/$defs/Output"
          },
          "type": "array",
          "description": "Output files to generate"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "inputs",
        "outputs"
      ]
    },
    "Step": {
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "add",
            "del"
          ],
          "description": "Operation to perform on matched input"
        },
        "input": {
          "type": "string",
          "description": "Reference to a named input defined above"
        },
        "include": {
          "items": {
            "type": "string",
            "examples": [
              "CN"
            ]
          },
          "type": "array",
          "description": "Process only these input categories"
        },
        "exclude": {
          "items": {
            "type": "string",
            "examples": [
              "RU"
            ]
          },
          "type": "array",
          "description": "Skip these input categories"
        },
        "options": {
          "$ref": "#/$defs/Options",
          "description": "Per-step transformation options"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "action",
        "input"
      ]
    }
  }
}